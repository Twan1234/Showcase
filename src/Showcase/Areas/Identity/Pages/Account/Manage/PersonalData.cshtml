@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3>@ViewData["Title"]</h3>

<div class="row">
    <div class="col-md-6">
        <p>Your account contains personal data that you have given us. This page allows you to download or delete that data.</p>
        <p><strong>Deleting this data will permanently remove your account. This cannot be recovered.</strong></p>

        <form asp-page-handler="DownloadPersonalData" method="post" class="form-group mb-3">
            <button class="btn btn-primary" type="submit">Download my data</button>
        </form>

        <p>
            <a asp-page="DeletePersonalData" class="btn btn-danger">Delete my account and data</a>
        </p>
    </div>
</div>
